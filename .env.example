# CrashSight Agent 环境变量配置
# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# ==================== CrashSight 用户鉴权 ====================
CS_USER_ID=
CS_USER_KEY=
CS_BASE_URL=https://crashsight.qq.com

# Cookie 认证（可选，仅 OpenAPI 不支持的接口需要）
CS_TOKEN_SKEY=
CS_TOKEN_LIFETIME=
CS_SESSION=
CS_GATEWAY_SESSION=

# ==================== CrashSight 项目 AppId/AppKey ====================
# Android 体验服
CS_ANDROID_EXP_APP_ID=
CS_ANDROID_EXP_APP_KEY=

# Android 正式服
CS_ANDROID_PROD_APP_ID=
CS_ANDROID_PROD_APP_KEY=

# iOS 体验服
CS_IOS_EXP_APP_ID=
CS_IOS_EXP_APP_KEY=

# iOS 正式服
CS_IOS_PROD_APP_ID=
CS_IOS_PROD_APP_KEY=

# Harmony 体验服
CS_HARMONY_EXP_APP_ID=
CS_HARMONY_EXP_APP_KEY=

# Harmony 正式服
CS_HARMONY_PROD_APP_ID=
CS_HARMONY_PROD_APP_KEY=

# ==================== TAPD ====================
TAPD_TOKEN=
TAPD_API_URL=https://apiv2.tapd.woa.com

# ==================== LLM ====================
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com

# ==================== Web 服务 ====================
# CORS 允许的域名（逗号分隔，默认仅本地）
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# SSL 验证（默认开启，设为 0 关闭，仅限内网调试）
# CS_VERIFY_SSL=1

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# LOG_LEVEL=INFO

# ==================== Agent 运行参数（可选，有默认值）====================
# MAX_TOOL_RETRIES=3
# CIRCUIT_BREAKER_THRESHOLD=3
# CIRCUIT_BREAKER_RECOVERY_SEC=60
# MAX_CONCURRENT_ISSUES=3
# RATE_LIMIT_PER_MINUTE=22
# MAX_STACK_TOKENS=1500
# MAX_CONTEXT_TOKENS=4000
# COMPRESS_THRESHOLD=3000
# HISTORY_SEARCH_LIMIT=10
# HISTORY_MAX_CANDIDATES=5
# JACCARD_THRESHOLD=0.3
# API_TIMEOUT=15
# TREND_API_TIMEOUT=30
# MAX_VERSIONS_RETURN=50
